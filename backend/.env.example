# ================================================================
#  .env.example — Backend PANdeMaiz Quake
#  Copiar a .env y completar con valores reales.
#  Este archivo SÍ se commitea (sin credenciales).
# ================================================================

# ── Firebase ──────────────────────────────────────────────────
# Ruta al JSON de cuenta de servicio (generado en Firebase Console).
# En Docker queda montado en /run/secrets/firebase.json (ver docker-compose.yml).
# En local, apuntar al archivo descargado.
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase.json
RTDB_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com/

# ── Email SMTP ────────────────────────────────────────────────
# Para Gmail: habilitar "Contraseñas de aplicación" en la cuenta.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alertas@ejemplo.com
SMTP_PASS=
SMTP_RECIPIENTS=admin@ejemplo.com,otro@ejemplo.com   # CSV

# ── Discord ───────────────────────────────────────────────────
# Crear webhook: Canal → Editar → Integraciones → Webhooks → Nuevo webhook.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Telegram ──────────────────────────────────────────────────
# 1. Hablar con @BotFather → /newbot → copiar el token
# 2. Crear un canal público, añadir el bot como administrador
#    con permiso "Publicar mensajes"
# 3. TELEGRAM_CHAT_ID = @nombre_del_canal  o  ID numérico
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@pandemaiz_alertas

# ── Motor de consenso ─────────────────────────────────────────
CONSENSUS_WINDOW_S=30        # Ventana en segundos para agregar alertas de distintas estaciones
MIN_STATIONS=2               # Mínimo de estaciones para disparar alerta global
GLOBAL_ALERT_COOLDOWN_S=300  # Cooldown entre alertas globales (5 minutos)
