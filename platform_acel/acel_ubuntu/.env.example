# ================================================================
#  .env.example — Plantilla pública de configuración
#  Copiar a .env y completar con valores reales.
#  Este archivo SÍ se commitea (sin credenciales).
# ================================================================

STATION_NAME=PANdeMaiz_01

# ── WiFi ──────────────────────────────────────────────────────
# Modo Personal (WPA2-PSK): llenar SSID + PASS, dejar IDENTITY y USERNAME vacíos
# Modo Enterprise (PEAP/MSCHAPv2): llenar los 4 campos
WIFI_SSID=MiRedWiFi
WIFI_PASS=MiContraseña
# Solo redes universitarias/empresariales:
WIFI_IDENTITY=anonimo@universidad.edu.co
WIFI_USERNAME=usuario@universidad.edu.co

# ── Coordenadas estáticas (fallback sin GPS) ──────────────────
# Usar cuando no hay módulo GPS, o como posición inicial mientras
# el GPS busca señal. Si el GPS obtiene fix real, lo reemplaza.
# Dejar en 0.0 si no se desea fallback (comportamiento original).
STATIC_LAT=0.0
STATIC_LON=0.0

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_USER_EMAIL=device@pandemaiz.com
FIREBASE_USER_PASS=
STORAGE_BUCKET_ID=
RTDB_URL=

